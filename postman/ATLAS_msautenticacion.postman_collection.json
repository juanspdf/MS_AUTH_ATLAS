			"name": "🔐 Auth",
			"description": "Endpoints de autenticación",
			"item": [
				{
					"name": "Login (admin/admin123)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('token', jsonData.datos.token);",
									"    pm.collectionVariables.set('usuarioId', jsonData.datos.idUsuario);",
									"    ",
									"    pm.test('Login exitoso', function () {",
									"        pm.expect(jsonData.status).to.eql(200);",
									"        pm.expect(jsonData.datos.token).to.be.a('string');",
									"        pm.expect(jsonData.datos.tipo).to.eql('Bearer');",
									"        pm.expect(jsonData.datos.rol).to.eql('ADMIN');",
									"    });",
									"    ",
									"    pm.test('Token guardado en variables', function () {",
									"        pm.expect(pm.collectionVariables.get('token')).to.not.be.empty;",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nombreUsuario\": \"admin\",\n    \"contrasenia\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Autentica al usuario y retorna un JWT.\n\nEl token se guarda automáticamente en la variable `{{token}}` para ser usado en los demás requests."
					},
					"response": []
				},
				{
					"name": "Login - Credenciales inválidas",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Retorna 401 Unauthorized', function () {",
									"    pm.response.to.have.status(401);",
									"});",
									"",
									"pm.test('Mensaje de error correcto', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.eql(401);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
